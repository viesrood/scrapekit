{
    "name": "viesrood/scrapekit",
    "description": "Fetch and query external HTML, XML or JSON straight from your Twig templates: CSS selectors, XPath, node traversal, and cached HTTP fetching for Craft CMS 5.",
    "type": "craft-plugin",
    "license": "MIT",
    "keywords": [
        "craft",
        "craftcms",
        "craft-plugin",
        "scraper",
        "scraping",
        "dom-crawler",
        "html",
        "xml",
        "json"
    ],
    "support": {
        "docs": "https://github.com/viesrood/scrapekit/blob/main/README.md",
        "issues": "https://github.com/viesrood/scrapekit/issues",
        "source": "https://github.com/viesrood/scrapekit"
    },
    "require": {
        "php": ">=8.2",
        "craftcms/cms": "^5.0.0",
        "symfony/dom-crawler": "^7.0",
        "symfony/css-selector": "^7.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "viesrood\\scrapekit\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true
        }
    },
    "scripts": {
        "check": [
            "@test",
            "@analyse"
        ],
        "test": "phpunit",
        "analyse": "phpstan analyse --no-progress --memory-limit=512M --debug"
    },
    "extra": {
        "handle": "scrapekit",
        "name": "ScrapeKit",
        "class": "viesrood\\scrapekit\\Plugin",
        "developer": "Viesrood",
        "developerUrl": "https://viesrood.nl",
        "documentationUrl": "https://github.com/viesrood/scrapekit"
    }
}
